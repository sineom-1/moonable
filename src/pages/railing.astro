---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/shared/HeroSection.astro';
import ComplianceShowcase from '../components/railing/ComplianceShowcase.astro';
import SceneGallery from '../components/railing/SceneGallery.astro';
import ContactCTA from '../components/shared/ContactCTA.astro';
import { getCollection } from 'astro:content';
import { CONTACT } from '../data/contact';

const projects = await getCollection('railing-projects');
---

<BaseLayout
  title="Aluminum Railings - Code-Compliant Installation | Moonable"
  description="Custom aluminum railing installation for homes in Ontario. Fully compliant with building codes. Front door, staircase, deck, and patio railings. Free on-site measurement."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Aluminum Railing Installation",
      "provider": {
        "@type": "LocalBusiness",
        "name": CONTACT.businessName,
        "url": "https://moonable.ca"
      },
      "areaServed": CONTACT.serviceArea,
      "description": "Custom aluminum railing installation for residential properties. Fully compliant with Ontario building codes."
    })} />
  </Fragment>

  <HeroSection
    badge="Code Compliant"
    title="Premium Aluminum Railing Installations"
    subtitle="Code-compliant, custom-installed aluminum railings for your home. Built to strict Ontario standards, engineered for endurance, and designed to elevate your property."
  >
      <a href="#gallery" class="w-full sm:w-auto bg-primary hover:bg-primary-hover text-white font-bold text-lg px-9 py-4 rounded-full transition-all shadow-xl shadow-primary/30 hover:-translate-y-1 hover:shadow-2xl text-center">
        View Our Projects
      </a>
      <a href="/contact" class="w-full sm:w-auto bg-white border border-border hover:border-primary text-text-main hover:text-primary font-bold text-lg px-9 py-4 rounded-full transition-all shadow-sm hover:shadow-md text-center">
        Get a Free Quote
      </a>
  </HeroSection>

  <ComplianceShowcase />

  <SceneGallery projects={projects} />

  <!-- How to Get a Quote -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16 flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-badge-bg mb-6">
          <span class="text-xs font-bold tracking-wider text-badge-text uppercase">Simple Process</span>
        </div>
        <h2 class="text-4xl lg:text-5xl font-extrabold text-text-main tracking-tight leading-tight">How to Get a Quote</h2>
        <p class="mt-6 text-lg lg:text-xl text-text-muted max-w-2xl mx-auto font-medium">
          Getting started is simple. Just follow these three easy steps.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 relative">
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-[28px] left-[15%] right-[15%] h-0.5 bg-border -z-10"></div>
        
        <div class="text-center relative">
          <div class="w-14 h-14 bg-white border-4 border-surface shadow-md text-primary rounded-full flex items-center justify-center mx-auto mb-6 text-xl font-black">
            1
          </div>
          <h3 class="font-bold text-xl text-text-main mb-3">Take 3 Photos</h3>
          <p class="text-text-muted font-medium leading-relaxed">Snap left, center, and right angle photos of your installation area.</p>
        </div>
        <div class="text-center relative">
          <div class="w-14 h-14 bg-white border-4 border-surface shadow-md text-primary rounded-full flex items-center justify-center mx-auto mb-6 text-xl font-black">
            2
          </div>
          <h3 class="font-bold text-xl text-text-main mb-3">Send to Us</h3>
          <p class="text-text-muted font-medium leading-relaxed">Email or text photos to us. Include a brief description of what you need.</p>
        </div>
        <div class="text-center relative">
          <div class="w-14 h-14 bg-primary border-4 border-surface shadow-lg text-white rounded-full flex items-center justify-center mx-auto mb-6 text-xl font-black">
            3
          </div>
          <h3 class="font-bold text-xl text-text-main mb-3">Get Your Quote</h3>
          <p class="text-text-muted font-medium leading-relaxed">We'll provide a detailed quote, or schedule a free on-site measurement if needed.</p>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    headline="Need a Detailed Quote?"
    description="Send us 3 photos of your area (left, center, right angles) and we'll get back to you with a comprehensive quote."
  />
</BaseLayout>
