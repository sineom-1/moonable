---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../data/contact';
---

<BaseLayout
  title="Contact Us | Moonable - Railings & Kayaks"
  description="Get in touch with Moonable for aluminum railing quotes or custom kayak orders."
>
  <section class="pt-24 pb-20 lg:pt-32 lg:pb-32 bg-surface relative overflow-hidden">
    <!-- Decorative abstract background -->
    <div class="absolute top-[-50%] left-1/2 -translate-x-1/2 w-[120vw] h-[120vw] bg-[radial-gradient(circle_at_center,_var(--color-primary)_0%,_transparent_40%)] opacity-[0.03] blur-3xl rounded-full pointer-events-none"></div>

    <div class="relative max-w-[1000px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16 flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-badge-bg mb-6">
          <span class="text-xs font-bold tracking-wider text-badge-text uppercase">Get in touch</span>
        </div>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-text-main tracking-tight leading-tight">Contact Us</h1>
        <p class="mt-6 text-lg lg:text-xl text-text-muted max-w-2xl mx-auto font-medium">
          Have a question about our railings or kayaks? We're here to help you start your next project.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-12">
        <!-- Phone -->
        <a
          href={`tel:${CONTACT.phone}`}
          class="group bg-white border border-border hover:border-primary/50 hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] p-10 text-center transition-all duration-300 hover:-translate-y-1"
        >
          <div class="w-16 h-16 bg-badge-bg group-hover:bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 transition-colors duration-300">
            <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-main mb-2">Call Us</h3>
          <p class="text-text-muted font-medium text-lg">{CONTACT.phone}</p>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${CONTACT.email}`}
          class="group bg-white border border-border hover:border-primary/50 hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] p-10 text-center transition-all duration-300 hover:-translate-y-1"
        >
          <div class="w-16 h-16 bg-badge-bg group-hover:bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 transition-colors duration-300">
            <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-main mb-2">Email Us</h3>
          <p class="text-text-muted font-medium text-lg">{CONTACT.email}</p>
        </a>
      </div>

      <!-- Service Area -->
      <div class="bg-primary text-white rounded-[2rem] p-10 text-center shadow-xl shadow-primary/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-primary-hover)_0%,_transparent_60%)] opacity-50 pointer-events-none"></div>
        <div class="relative z-10">
          <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-3">Service Area</h3>
          <p class="text-white/90 font-medium text-lg mb-2">{CONTACT.serviceArea}</p>
          <p class="text-sm text-white/70">Free on-site measurement available for local railing projects.</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="mt-20 text-center border-t border-border pt-16">
        <h2 class="text-2xl font-bold text-text-main mb-8">What Are You Looking For?</h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <a href="/railing" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white hover:bg-surface text-text-main border border-border font-bold px-8 py-4 rounded-full transition-all shadow-sm hover:shadow-md">
            Aluminum Railings
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/kayak" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white hover:bg-surface text-text-main border border-border font-bold px-8 py-4 rounded-full transition-all shadow-sm hover:shadow-md">
            Custom Kayaks
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
