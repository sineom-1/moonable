---
import { CONTACT } from '../../data/contact';
import { NAV_LINKS } from '../../data/navigation';
---

<footer class="bg-surface border-t border-border mt-auto">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-16 lg:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 text-primary font-bold text-2xl tracking-tight mb-8">
          <div class="relative w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
             <div class="absolute inset-0 bg-primary opacity-20 transform rotate-12 rounded-xl"></div>
             <svg class="w-6 h-6 text-primary relative z-10" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13H5.5L12 6.5z"/>
             </svg>
          </div>
          <span class="text-text-main">Moonable</span>
        </a>
        <p class="text-text-muted text-lg leading-relaxed max-w-sm mb-8 font-medium">
          Your trusted partner for code-compliant aluminum railings and custom-designed kayaks in Ontario, Canada.
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-white text-xs font-bold tracking-wider text-text-main shadow-sm">
          <span>🇨🇦</span> Locally Manufactured
        </div>
      </div>

      <div>
        <h4 class="font-bold text-text-main text-lg mb-6 tracking-wide">Company</h4>
        <ul class="space-y-4">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-text-muted hover:text-primary transition-colors flex items-center gap-2 group font-semibold">
                <span class="w-1.5 h-1.5 rounded-full bg-border group-hover:bg-primary transition-colors"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-text-main text-lg mb-6 tracking-wide">Get in Touch</h4>
        <ul class="space-y-5 text-text-muted font-medium">
          <li>
            <a href={`tel:${CONTACT.phone}`} class="hover:text-primary transition-colors flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-border">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              {CONTACT.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${CONTACT.email}`} class="hover:text-primary transition-colors flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-border">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              {CONTACT.email}
            </a>
          </li>
          <li class="flex items-start gap-3 pt-2">
            <div class="w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center border border-border shrink-0">
               <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <span>{CONTACT.serviceArea}<br/><span class="text-sm opacity-80">{CONTACT.address}</span></span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-text-muted font-medium">
      <p>&copy; {new Date().getFullYear()} {CONTACT.businessName}. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
