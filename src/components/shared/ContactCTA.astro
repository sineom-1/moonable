---
import { CONTACT } from '../../data/contact';

interface Props {
  headline?: string;
  description?: string;
}

const {
  headline = 'Ready To Elevate Your Property?',
  description = "Get in touch today for a free consultation. We're here to help with your aluminum railing or custom kayak project.",
} = Astro.props;
---

<section class="py-24 lg:py-32 bg-primary relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -mt-20 -mr-20 w-80 h-80 bg-white opacity-5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-80 h-80 bg-white opacity-5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-12 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 mb-6 text-white text-xs font-bold tracking-wider uppercase border border-white/20">
      Get Started
    </div>
    
    <h2 class="text-4xl lg:text-5xl font-extrabold text-white mb-6 tracking-tight leading-tight">{headline}</h2>
    <p class="text-lg lg:text-xl text-white/80 mb-10 max-w-2xl mx-auto font-medium">{description}</p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 w-full sm:w-auto">
      <a
        href={`tel:${CONTACT.phone}`}
        class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-white hover:bg-surface text-primary font-bold px-9 py-4 rounded-full transition-all shadow-xl hover:-translate-y-1 hover:shadow-2xl"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Us Now
      </a>
      <a
        href={`mailto:${CONTACT.email}`}
        class="w-full sm:w-auto inline-flex justify-center items-center gap-2 border-2 border-white/30 text-white hover:border-white font-bold px-9 py-4 rounded-full transition-all"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Email Us
      </a>
    </div>
  </div>
</section>
