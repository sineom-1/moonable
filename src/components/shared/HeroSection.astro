---
interface Props {
  title: string;
  subtitle: string;
  badge?: string;
}

const { title, subtitle, badge } = Astro.props;
---

<section class="relative pt-20 pb-24 lg:pt-32 lg:pb-32 bg-surface overflow-hidden">
  <!-- Decorative abstract background -->
  <div class="absolute top-[-50%] left-1/2 -translate-x-1/2 w-[120vw] h-[120vw] bg-[radial-gradient(circle_at_center,_var(--color-primary)_0%,_transparent_40%)] opacity-[0.03] blur-3xl rounded-full pointer-events-none"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-12 text-center flex flex-col items-center">
    {badge && (
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-badge-bg mb-8">
        <span class="text-xs font-bold tracking-wider text-badge-text uppercase">{badge}</span>
      </div>
    )}

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-main mb-8 leading-[1.15] tracking-tight max-w-4xl">
      {title}
    </h1>
    
    <p class="text-lg lg:text-xl text-text-muted max-w-2xl mx-auto mb-12 font-medium leading-relaxed">
      {subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
      <slot />
    </div>
  </div>
</section>
